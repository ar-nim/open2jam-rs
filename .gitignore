# Resources - distributed separately (submodule)
/resources/

# Runtime-generated Fyrox data (resource registry)
data/

# Qwen Code settings (user-specific)
.qwen/

# Temporary documentation (auto-generated, not for version control)
tmpdocs/

# Generated by Cargo
debug/
target/
target-*/

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
**/mutants.out*/

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# RustAnalyzer
.rust-analyzer/

# Environment variables
.env
.env.local

# Build output for release
*.dll
*.exe
*.so
*.dylib

# Flamegraph profiling
flamegraph.svg

# Coverage reports
*.gcno
*.gcda
coverage/
*.lcov
tarpaulin-report.html

# Benchmark results
criterion/

# Temporary files
tmp/
temp/
*.tmp

# Test assets (user-provided OJN/OJM files - not tracked)
test_assets/*.ojn
test_assets/*.ojm
test_assets/*.ogg
test_assets/*.mp3
test_assets/*.zip

# Logs
*.log

# Minidumps
*.dmp

# Fonts
crates/game/assets/*.ttf


